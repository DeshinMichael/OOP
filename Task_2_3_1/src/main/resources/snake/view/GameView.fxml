<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="snake.controller.GameController">
    <top>
        <HBox alignment="CENTER" spacing="15" style="-fx-padding: 15; -fx-background-color: #1f2937; -fx-background-radius: 8;">
            <Label text="Level:" style="-fx-text-fill: #9ca3af; -fx-font-size: 18px;"/>
            <Label fx:id="levelLabel" text="1" style="-fx-text-fill: #10b981; -fx-font-weight: bold; -fx-font-size: 18px;"/>
            <Label text="|" style="-fx-text-fill: #4b5563; -fx-font-size: 18px;"/>
            <Label text="Length:" style="-fx-text-fill: #9ca3af; -fx-font-size: 18px;"/>
            <Label fx:id="lengthLabel" text="1" style="-fx-text-fill: #10b981; -fx-font-weight: bold; -fx-font-size: 18px;"/>
            <Label text="|" style="-fx-text-fill: #4b5563; -fx-font-size: 18px;"/>
            <Label text="Status:" style="-fx-text-fill: #9ca3af; -fx-font-size: 18px;"/>
            <Label fx:id="statusLabel" text="READY" style="-fx-text-fill: #3b82f6; -fx-font-weight: bold; -fx-font-size: 18px;"/>
        </HBox>
    </top>
    <center>
        <StackPane fx:id="boardContainer" style="-fx-padding: 20 0 0 0;">
            <Canvas fx:id="bgCanvas" width="600" height="600"/>
            <Canvas fx:id="boardCanvas" width="600" height="600"/>
        </StackPane>
    </center>
</BorderPane>
